# ------------------------------
# Frontend (Vite)
# ------------------------------
# IMPORTANT: VITE_* values are embedded in browser code at build time.
# Do NOT put secrets here.
VITE_APP_NAME=Nontronics
VITE_SITE_URL=https://nontronics.com

# ------------------------------
# Backend / PHP contact endpoint
# ------------------------------
# Comma-separated host allow-list used for Origin/Referer checks.
APP_ALLOWED_HOSTS=nontronics.com,www.nontronics.com,nontronics.tech,www.nontronics.tech,localhost,127.0.0.1

BUSINESS_NAME=Nontronics Group
BUSINESS_BRAND=Nontronics
LOGO_URL=https://nontronics.com/assets/nontronicsbwplog.png

# Contact routing
CONTACT_ADMIN_EMAIL=you@example.com
CONTACT_ADMIN_CC=admin1@example.com,admin2@example.com

# SMTP mail transport
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# tls or ssl
SMTP_ENCRYPTION=tls
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace-with-real-secret
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Nontronics Group
